{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "target": "ES2023",
    "jsx": "react",
    "allowImportingTsExtensions": false,
    "checkJs": true,
    "strictNullChecks": true,
    "allowJs": true,
    "strictFunctionTypes": true,
    "lib": [
      "DOM",
      "ESNext"
    ],
  },
  "include": [
    "./**/*.d.ts",
    "./**/*.js"
  ]
}